# Copy to .env for local dev. In production (Railway) these are injected as
# service env vars, so no .env file is needed there.
# Only DATABASE_URL is strictly required; everything else has a sensible default
# (the chat/alert/broker blocks are required only if you use those features).
#
# NEVER put real secrets in this file — it is committed to git. Use placeholders.

# --- Core ---
DATABASE_URL=postgresql://user:password@host:port/dbname
# PORT=8920                       # server port (Railway injects its own)

# --- Chat agent (ticker + portfolio desks) ---
# Provider is inferred from CHAT_MODEL: gemini-* -> Google, else Anthropic.
# Set the matching key. No key -> the /chat routes return 503.
GEMINI_API_KEY=                   # Google AI Studio key (AIza...) for gemini-* models
# ANTHROPIC_API_KEY=              # set instead if CHAT_MODEL is a claude-* model
CHAT_MODEL=gemini-2.5-pro         # default; e.g. gemini-2.5-flash / claude-opus-4-8
# NEWS_MODEL=gemini-2.5-flash     # get_news web-grounded sub-call (reuses GEMINI_API_KEY)
# BIBLE_DIR=                      # override the bible source dir; defaults to the
#                                 # vendored snapshot in server/reference/bible

# --- Risk model (Zero bible §12–13; all optional, shown with defaults) ---
# ACCOUNT_SIZE=20000              # £, drives position sizing
# RISK_PER_TRADE=0.02            # 2% of account per trade (MTF)
# MIN_RR=2                        # minimum reward:risk

# --- Headless Claude (skeptical-editor synthesis; LOCAL ONLY) ---
# Spawns a local claude binary — does NOT run on Railway. Synthesis is a local
# admin task; the deployed app still reads existing synthesis from the DB.
# CLAUDE_BIN=/Applications/cmux.app/Contents/Resources/bin/claude
# CLAUDE_MODEL=                   # '' = inherit default
# RUN_TIMEOUT_MS=720000           # 12 min per synthesis run

# --- Alerts (engine grounded in tickers-with-plans) ---
# Required to deliver alerts + let the Trigger.dev cron poke POST /api/alerts/run.
TELEGRAM_BOT_TOKEN=               # from @BotFather (reuse the alert bot's)
TELEGRAM_CHAT_ID=                 # destination chat/channel id
ALERTS_RUN_TOKEN=                 # shared secret; must match alerts/ project's value
# ALERT_NEAR=0.05                 # target-proximity for "near target"
# ALERT_COOLDOWN_H=6              # per (symbol,transition) re-fire suppression (hours)
# ALERT_POINT_BAND=0.01           # widen a synthesis point-entry into a ±band

# --- Brokers (read-only account sync; all optional) ---
# Per-account credentials are encrypted with this key — REQUIRED for any broker
# sync to run. Generate one: openssl rand -hex 32
APP_ENCRYPTION_KEY=
# Trading 212: JSON array of accounts (each with its own API key/secret).
T212_ACCOUNTS=[{"id":"main","label":"ISA","keyId":"YOUR_T212_KEY_ID","secret":"YOUR_T212_SECRET","baseUrl":"https://live.trading212.com"}]
# Bitget spot (read-only):
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
# SnapTrade (AJ Bell JISA etc.):
# SNAPTRADE_CLIENT_ID=
# SNAPTRADE_CONSUMER_KEY=
# SNAPTRADE_USER_ID=

# --- Paths / misc (optional overrides; defaults are fine) ---
# MEDIA_DIR=                      # default <root>/media (chart images; see DEPLOY.md)
# PRICE_CACHE_FILE=               # default data/price-cache.json
# PRICE_HIST_FILE=                # default data/price-history.json
